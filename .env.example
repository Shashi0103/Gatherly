# ==============================================================================
# GATHERLY ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' in the root for server-side configurations.
# Copy or create a '.env' under 'client/.env' for React front-end configurations.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SERVER CONFIGURATIONS (server/.env or root .env)
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Connection String (Atlas or Local)
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/gatherly
MONGODB_URI=mongodb://localhost:27017/gatherly

# Custom JWT Authentication Secrets
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# 2. CLIENT CONFIGURATIONS (client/.env)
# ------------------------------------------------------------------------------
# URL pointing to the node.js/socket.io server
VITE_API_URL=http://localhost:5000
